# Copy to .env and fill values
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=1162752434
PORT=3000
NODE_ENV=development

# SECURITY: Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=https://burabay.su,https://www.burabay.su,http://localhost:3000

# OPTIONAL: Webhook URL for contact form (e.g., Zapier, Make.com, custom service)
# CONTACT_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/YOUR_WEBHOOK_ID

# SECURITY: do NOT commit .env with real tokens to git
# For Docker, set environment variables in your host or CI/CD secrets

{
  "routes": [
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "adil.alsat.asia" }],
      "dest": "/business.html"
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "burabay.su" }],
      "status": 302,
      "headers": { "Location": "https://alsat.asia/notice.html" }
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "www.burabay.su" }],
      "status": 302,
      "headers": { "Location": "https://alsat.asia/notice.html" }
    }
  ]
}
